"""
This program is for the Shaft Design Project for Machine Design.

PURPOSE:
This program analyzes a rotating shaft subjected to bending, torsion,
axial, or combined loading. It can:

1) Calculate a required shaft diameter for a desired safety factor.
2) Calculate a safety factor for a given shaft diameter.

The program considers:
- Yield failure (Von Mises or conservative approach)
- Fatigue failure (Goodman relation)
- Stress concentration effects
- Surface finish effects
- Size effects
- Material strength properties

The program uses the Bisection Method when solving for diameter.
"""

import numpy as np

def main():
    """
    Main driver function for the shaft design project.

    This function:
    - Collects all user inputs
    - Determines whether to compute diameter or safety factor
    - Calls helper functions
    - Displays final results
    """

    while True:    
        # ===================================================================
        #                    SHAFT CHARACTERISTIC INPUTS 
        # ===================================================================

        # Measurement system selection (determines unit assumptions)
        system = input("Enter the measurment system (metric or imperial): ").strip().lower()
        if system == "q":
            print("\nExiting program. Goodbye!\n")
            break
        
        # Surface finish affects endurance limit correction factor
        finish = input("Enter the finish of the shaft (ground, machined/cold-drawn, hot-rolled, or as-forged): ").strip().lower()
        if finish == "q":
            print("\nExiting program. Goodbye!\n")
            break

        # Type of loading applied to shaft
        condition = input("Enter the shaft stress condition (bending, torsion, axial, or combined): ").strip().lower()
        if condition == "q":
            print("\nExiting program. Goodbye!\n")
            break

        # Initial geometric assumption for stress concentration
        # Used to estimate Kt and Kts values
        iter_estimate = input("Enter the stress concentration factor type for Kt and Kts (ring-groove, keyway, wide radius, sharp radius): ").strip().lower()
        if iter_estimate == "q":
            print("\nExiting program. Goodbye!\n")
            break

        # ===================================================================
        #                      MATERIAL PROPERTY INPUTS
        # ===================================================================

        # Ultimate tensile strength of the material
        Sut = input("Enter the ultimate tensile strength of the material (in KSI or MPa): ").strip().lower()
        if Sut == "q":
            print("\nExiting program. Goodbye!\n")
            break
        else:            
            try:
                Sut = float(Sut)
            except ValueError:
                print(f"\n'{Sut}' is not a valid number. Please enter a numeric value for the ultimate tensile strength.\n")
                continue

        # Yield strength of the material
        Sy = input("Enter the yield strength of the material (in KSI or MPa): ").strip().lower()
        if Sy == "q":
            print("\nExiting program. Goodbye!\n")
            break
        else:            
            try:
                Sy = float(Sy)
            except ValueError:
                print(f"\n'{Sy}' is not a valid number. Please enter a numeric value for the yield strength.\n")
                continue

        # ===================================================================
        #                          LOADING INPUTS
        # ===================================================================

        # Alternating bending moment on the shaft
        Ma = input("Enter the bending moment on the shaft (in lb-in or N-mm): ").strip().lower()
        if Ma == "q":
            print("\nExiting program. Goodbye!\n")
            break
        else:
            try:
                Ma = float(Ma)
            except ValueError:
                print(f"\n'{Ma}' is not a valid number. Please enter a numeric value for the bending moment.\n")
                continue

        # Mean torque on the shaft
        Tm = input("Enter the torque on the shaft (in lb-in or N-mm): ").strip().lower()
        if Tm == "q":
            print("\nExiting program. Goodbye!\n")
            break
        else:
            try:
                Tm = float(Tm)
            except ValueError:
                print(f"\n'{Tm}' is not a valid number. Please enter a numeric value for the torque.\n")
                continue

        # ===================================================================
        #                         ASSUMED CONSANTS
        # ===================================================================

        Mm = 0 # Assuming no mean bending moment, so the mean normal stress is zero
        Ta = 0 # Assuming no alternating torque, so the alternating shear stress is zero

        # ===================================================================
        #            DETERMINING FINDING DIAMETER OR SAFETY FACTOR
        # ===================================================================

        d_check = input("Do you want to enter a diameter for the shaft? (yes or no): ").strip().lower()
        if d_check == "q":
            print("\nExiting program. Goodbye!\n")
            break

        # ===================================================================
        #       MODE 1: DIAMETER IS PROVIDED --> COMPUTE SAFETY FACTOR
        # ===================================================================

        if d_check == "yes":
            d = input("Enter the diameter of the shaft (in in. or mm): ").strip().lower() # Assuming this is the effective diameter
            if d == "q":
                print("\nExiting program. Goodbye!\n")
                break
            else:
                try:
                    d = float(d)
                except ValueError:
                    print(f"\n'{d}' is not a valid number. Please enter a numeric value for the diameter of the shaft.\n")
                    continue
        
        # ===================================================================
        #       MODE 2: SAFETY FACTOR IS PROVIDED --> COMPUTE DIAMETER
        # ===================================================================

        elif d_check == "no":
            n = input("Enter the desired safety factor: ").strip().lower()
            if n == "q":
                print("\nExiting program. Goodbye!\n")
                break
            else:
                try:
                    n = float(n)
                except ValueError:
                    print(f"\n'{n}' is not a valid number. Please enter a numeric value for the safety factor.\n")
                    continue

            # Compute diameter using BOTH methods
            dc = ConservativeDiameter(n, Sut, Sy, condition, system, finish, iter_estimate, Ma, Mm, Ta, Tm)
            dg = GoodmanDiameter(n, Sut, Sy, condition, system, finish, iter_estimate, Ma, Mm, Ta, Tm)

            # Choose larger (more conservative) diameter for safety
            d = max(dc, dg)
            print(f"\nCalculated diameter: {d:.3f}\n")

            break
        
        else:
            print(f"\nError: '{d_check}' is not a valid response. Please enter 'yes' or 'no'.\n")
            continue

        # ===================================================================
        #                   SAFETY FACTOR TYPE SELECTION
        # ===================================================================

        # Yield or fatigue safety factor
        SF = input("Enter the desired safety factor (yield, fatigue): ").strip().lower()
        if SF == "q":
            print("\nExiting program. Goodbye!\n")
            break

        # Type of Safety Factor
        SFtype = input("Enter the type of safety factor (goodman, von mises, conservative): ").strip().lower()
        if SFtype == "q":
            print("\nExiting program. Goodbye!\n")
            break
    
        # ===================================================================
        #      CALLING CORE CALCULATION FUNCTIONS USING DIAMETER INPUT
        # ===================================================================
        Se = EnduranceLimit(Sut, system, finish, condition, d)
        Kf, Kfs = StressConcentration(condition, system, Sut, iter_estimate, d)
        sigma_max_prime, sigma_a_prime, sigma_m_prime, A, B, sigma_m, sigma_a = ShaftStresses(Kf, Kfs, Ma, Mm, Ta, Tm, d)
        ny, nf = SafetyFactor(Sy, sigma_max_prime, sigma_a_prime, sigma_m_prime, SF, SFtype, Se, Sut, sigma_m, sigma_a, d, A, B)

        # ===================================================================
        #                  DISPLAYING SAFETY FACTOR RESULTS
        # ===================================================================
        if SF == "yield" and SFtype == "von mises":
            print(f"\nVon Mises safety factor against yielding: {ny:.3f}\n\n")
        elif SF == "yield" and SFtype == "conservative":
            print(f"\nConservative safety factor against yielding: {ny:.3f}\n\n")
        elif SF == "fatigue" and SFtype == "goodman":
            print(f"\nGoodman safety factor against fatigue: {nf:.3f}\n\n")

        break

# ===================================================================
#                 DIAMETER SOLVERS (BISECTION METHOD)
# ===================================================================

def ConservativeDiameter(n, Sut, Sy, condition, system, finish, iter_estimate, Ma, Mm, Ta, Tm):
    """
    Solves for shaft diameter using conservative yield criterion.

    Uses Bisection Method to solve:
        f(d) = calculated_safety_factor(d) - target_safety_factor

    Root occurs when safety factor equals desired value.
    """

    # ===================================================================
    #                INITIAL BOUNDS AND SETUP FOR BISECTION
    # ===================================================================

    xl = 0.1          # Lower bound for diameter
    xu = 10.0         # Upper bound for diameter
    tol = 0.0001      # Convergence tolerance
    max_iter = 10000  # Max iterations

    # ===================================================================
    #     FUNCTION TO COMPUTE SAFETY FACTOR DIFFERENCE FOR BISECTION
    # ===================================================================

    def f(d):
        """Returns n_sf(d) - n. Bisection finds where this equals zero."""
        
        # Hardcode conservative yield
        SF_inner = "yield"
        SFtype_inner = "conservative"

        # Recalculate everything at this diameter
        Se = EnduranceLimit(Sut, system, finish, condition, d)
        Kf, Kfs = StressConcentration(condition, system, Sut, iter_estimate, d)
        sigma_max_prime, sigma_a_prime, sigma_m_prime, A, B, sigma_m, sigma_a = ShaftStresses(Kf, Kfs, Ma, Mm, Ta, Tm, d)
        ny, nf = SafetyFactor(Sy, sigma_max_prime, sigma_a_prime, sigma_m_prime, SF_inner, SFtype_inner, Se, Sut, sigma_m, sigma_a, d, A, B)

        return ny - n  # Zero when computed safety factor matches target

    # ===================================================================
    #   INITIALIZING BISECTION WITH A CHECK FOR A ROOT IN THE INTERVAL
    # ===================================================================

    f_xl = f(xl)
    f_xu = f(xu)

    if f_xl * f_xu > 0:
        print("\nNo sign change between bounds — bisection cannot find a root.")
        print(f"  f({xl}) = {f_xl:.4f}, f({xu}) = {f_xu:.4f}")
        print("Try adjusting your target safety factor or input values.\n")
        return None

    # ===================================================================
    #                         BISECTION METHOD
    # ===================================================================

    for i in range(max_iter):
        d = (xl + xu) / 2  # Midpoint — current best guess

        f_d = f(d)

        # Check convergence: interval is small enough
        if abs(xu - xl) / 2 < tol:
            print(f"\nConservative diameter: {d:.4f} after {i+1} iterations.")
            return d

        # Narrow the interval toward the root
        if f_xl * f_d < 0:
            xu = d          # Root is in left half
        else:
            xl = d          # Root is in right half
            f_xl = f_d      # Update f_xl to match new lower bound

    print("\nWarning: max iterations reached. Returning best estimate.")
    return d

def GoodmanDiameter(n, Sut, Sy, condition, system, finish, iter_estimate, Ma, Mm, Ta, Tm):
    """
