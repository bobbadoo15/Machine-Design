def EnduranceLimit(Sut, system, finish, condition, d):
    """
    Calculates the corrected endurance limit (Se) of the shaft material.

    PARAMETERS:
    Sut       : Ultimate tensile strength (KSI or MPa)
    system    : 'imperial' or 'metric'
    finish    : Surface finish of shaft
    condition : Loading type (bending, torsion, axial, combined)
    d         : Shaft diameter

    RETURNS:
    Se : Fully corrected endurance limit

    METHOD:
    1) Determine base endurance limit (Se')
    2) Apply Marin correction factors:
        - Surface finish factor (ka)
        - Size factor (kb)
        - Load factor (kc)
        - Temperature factor (kd)
        - Reliability factor (ke)
        - Miscellaneous factor (kf)
    3) Multiply all factors together
    """

    # Endurance limit without correction factors (Se')
    if system == "imperial":
        if Sut <= 200:     # KSI
            Se_prime = 0.5 * Sut
        else:
            Se_prime = 100 # KSI
    elif system == "metric":
        if Sut <= 1400:    # MPa
            Se_prime = 0.5 * Sut
        else:
            Se_prime = 700 # MPa

    # Surface Finish Variables
    if system == "imperial":
        if finish == "ground":
            a = 1.21 # Sut in KSI
            b = -0.067
        elif finish == "machined" or finish == "cold-drawn":
            a = 2.00 # Sut in KSI
            b = -0.217
        elif finish == "hot-rolled":
            a = 11.0 # Sut in KSI
            b = -0.65
        elif finish == "as-forged":
            a = 12.7 # Sut in KSI
            b = -0.758
        else:
            print(f"\nError: '{finish}' is not a valid finish. Please enter 'ground', 'machined', or 'hot-rolled'.\n")
    elif system == "metric":
        if finish == "ground":
            a = 1.38 # Sut in MPa
            b = -0.067
        elif finish == "machined" or finish == "cold-drawn":
            a = 3.04 # Sut in MPa
            b = -0.217
        elif finish == "hot-rolled":
            a = 38.6 # Sut in MPa
            b = -0.65
        elif finish == "as-forged":
            a = 54.9 # Sut in MPa
            b = -0.758
        else:
            print(f"\nError: '{finish}' is not a valid finish. Please enter 'ground', 'machined', or 'hot-rolled'.\n")
    else:
        print(f"\nError: '{system}' is not a valid measurement system. Please enter 'imperial' or 'metric'.\n")

    # Endurance Limit factors
    ka = a * (Sut ** b)
    if condition == "axial":
        kb = 1.0
    elif condition == "bending" or condition == "torsion" or condition == "combined":
        if system == "imperial":
            if d >= 0.3 and d <= 2.0:   # inches
                kb = (d/0.3)**-0.107
            elif d > 2.0 and d <= 10.0: # inches
                kb = 0.91*d**-0.157
            elif d < 0.3:               # inches
                kb = 1.0
            else:
                print(f"\nError: '{d}' is not a valid diameter for the bending condition. Please enter a diameter between 0.3 and 10 inches.\n")
        elif system == "metric":
            if d >= 7.62 and d <= 51: # mm
                kb = (d/7.62)**-0.107
            elif d > 51 and d <= 254: # mm
                kb = 1.51*d**-0.157
            elif d < 7.62:            # mm
                kb = 1.0
            else:
                print(f"\nError: '{d}' is not a valid diameter for the bending condition. Please enter a diameter between 8 and 250 mm.\n")
    if condition == "bending" or condition == "combined":
        kc = 1.0  # Assuming torsion in combination with bending or axial loading when 'combined' is selected
    elif condition == "torsion":
        kc = 0.59
    elif condition == "axial":
        kc = 0.85
    else:
        print(f"\nError: '{condition}' is not a valid shaft stress condition. Please enter 'bending', 'torsion', or 'axial'.\n")
    kd = 1.0 # Assuming the endurance limit, Se_prime, is available or estimated based on the Sut value of the material
    ke = 1.0 # Project description assumes no additional information is given about the reliability; assuming a reliability of 50% which corresponds to a factor of 1.0
    kf = 1.0 

    # Calculate the endurance limit with factors
    Se = Se_prime * ka * kb * kc * kd * ke * kf

    return Se

def SafetyFactor(Sy, sigma_max_prime, sigma_a_prime, sigma_m_prime, SF, SFtype, Se, Sut, sigma_m, sigma_a, d, A, B):
    """
    Calculates safety factor against yielding or fatigue failure.

    PARAMETERS:
    Sy                : Yield strength
    sigma_max_prime   : Maximum Von Mises stress
    sigma_a_prime     : Alternating Von Mises stress
    sigma_m_prime     : Mean Von Mises stress
    SF                : 'yield' or 'fatigue'
    SFtype            : Method (von mises, conservative, goodman)
    Se                : Endurance limit
    Sut               : Ultimate strength
    sigma_m           : Mean normal stress
    sigma_a           : Alternating normal stress
    d, A, B           : Parameters used in Goodman equation

    RETURNS:
    ny : Yield safety factor
    nf : Fatigue safety factor

    METHODS IMPLEMENTED:
    - Von Mises Yield Criterion
    - Conservative Yield Criterion
    - Modified Goodman Fatigue Criterion
    """

    # Initialize safety factors to None
    ny = None
    nf = None

    # Yield safety factor calculations
    if SF == "yield":
        if SFtype == "von mises":
            ny = Sy / sigma_max_prime
        elif SFtype == "conservative":
            ny = Sy / (sigma_a_prime + sigma_m_prime)
        else:
            print(f"\nError: '{SFtype}' is not a valid type of safety factor. Please enter 'von mises' or 'conservative'.\n")
    
    # Fatigue safety factor calculations
    elif SF == "fatigue":
        if SFtype == "goodman":
            nf = (np.pi * d**3 / 16) * ((A / (1000 * Se)) + (B / (1000 * Sut)))**-1
        else:
            print(f"\nError: '{SFtype}' is not a valid type of safety factor. Please enter 'goodman'.\n")
    else:
        print(f"\nError: '{SF}' is not a valid type of safety factor. Please enter 'yield' or 'fatigue'.\n")

    return ny, nf

def ShaftStresses(Kf, Kfs, Ma, Mm, Ta, Tm, d):
    """
    Computes alternating and mean stresses in the shaft.

    PARAMETERS:
    Kf  : Fatigue stress concentration factor (normal)
    Kfs : Fatigue stress concentration factor (shear)
    Ma  : Alternating bending moment
    Mm  : Mean bending moment
    Ta  : Alternating torque
    Tm  : Mean torque
    d   : Shaft diameter

    RETURNS:
    sigma_max_prime : Maximum Von Mises stress
    sigma_a_prime   : Alternating Von Mises stress
    sigma_m_prime   : Mean Von Mises stress
    A, B            : Simplified load expressions for fatigue equation
    sigma_m         : Mean normal stress
    sigma_a         : Alternating normal stress

    METHOD:
    - Compute bending and torsional stresses
    - Apply stress concentration factors
    - Compute Von Mises equivalent stresses
    - Compute combined load parameters (A and B)
    """

    # Calculating the alternating stresses
    sigma_a = (32 * Ma * Kf) / (np.pi * d**3 * 1000)
    tau_a = (Kfs * 16 * Ta) / (np.pi * d**3 * 1000) # Assuming no alternating torque, so the alternating shear stress is zero

    # Calculating the mean stresses
    sigma_m = (Kf * 32 * Mm) / (np.pi * d**3 * 1000) # Assuming no mean bending moment, so the mean normal stress is zero
    tau_m = (16 * Tm * Kfs) / (np.pi * d**3 * 1000)

    # Variables for simplification
    A = np.sqrt(4*(Kf*Ma)**2 + 3*(Kfs*Ta)**2)
    B = np.sqrt(4*(Kf*Mm)**2 + 3*(Kfs*Tm)**2)

    # Calculating the alternating Von Mises stress
    sigma_a_prime = np.sqrt(sigma_a**2 + 3*tau_a**2)

    # Calculating the mean Von Mises stress
    sigma_m_prime = np.sqrt(sigma_m**2 + 3*tau_m**2)

    # Calculating the Maximum Von Mises stress
    sigma_max_prime = np.sqrt((sigma_m + sigma_a)**2 + 3*(tau_m + tau_a)**2)

    return sigma_max_prime, sigma_a_prime, sigma_m_prime, A, B, sigma_m, sigma_a

def StressConcentration(condition, system, Sut, iter_estimate, d):
    """
    Calculates fatigue stress concentration factors (Kf and/or Kfs).

    PARAMETERS:
    condition     : Type of loading (bending, torsion, axial, combined)
    system        : Unit system (imperial or metric)
    Sut           : Ultimate tensile strength
    iter_estimate : Geometric assumption (keyway, groove, radius type)
    d             : Shaft diameter

    RETURNS:
    Kf  : Fatigue stress concentration factor (normal stress)
    Kfs : Fatigue stress concentration factor (shear stress)

    METHOD:
    1) Assign theoretical stress concentration factors (Kt, Kts)
    2) Estimate notch radius R
    3) Compute Neuber constant (material dependent)
    4) Compute notch sensitivity (q or qs)
    5) Compute fatigue stress concentration factors:
            Kf  = 1 + q (Kt - 1)
            Kfs = 1 + qs (Kts - 1)
    """
    
    # Step 1: Assign theoretical stress concentration factors (Kt, Kts) and notch radius (R) based on geometry and loading condition
    if iter_estimate == "ring-groove":
        if condition == "bending" or condition == "axial":
            Kt = 5.0
            R = 0.01 # inches
        elif condition == "torsion":
            Kts = 3.0
            R = 0.01 # inches
        elif condition == "combined":
            Kt = 5.0
            Kts = 3.0
            R = 0.01 # inches
        else:
            print(f"\nError: '{condition}' is not a valid shaft stress condition. Please enter 'bending', 'torsion', or 'axial'.\n")
    elif iter_estimate == "keyway":
        if condition == "bending":
            Kt = 2.14
            R = 0.02 * d # inches
        elif condition == "torsion":
            Kts = 3.0
            R = 0.02 * d # inches
        elif condition == "combined":
            Kt = 2.14
            Kts = 3.0
            R = 0.02 * d # inches
        else:
            print(f"\nError: '{condition}' is not a valid shaft stress condition. Please enter 'bending', 'torsion', or 'axial'.\n")
    elif iter_estimate == "wide radius":
        if condition == "bending": 
            Kt = 1.7
            R = 0.1 * d # inches
        elif condition == "torsion":
            Kts = 1.5
            R = 0.1 * d # inches
        elif condition == "axial":
            Kt = 1.9
            R = 0.1 * d # inches
        elif condition == "combined":
            Kt = 1.7
            Kts = 1.5
            R = 0.1 * d # inches
        else:
            print(f"\nError: '{condition}' is not a valid shaft stress condition. Please enter 'bending', 'torsion', or 'axial'.\n")
    elif iter_estimate == "sharp radius":
        if condition == "bending": 
            Kt = 2.7
            R = 0.02 * d # inches
        elif condition == "torsion":
            Kts = 2.2
            R = 0.02 * d # inches
        elif condition == "axial":
            Kt = 3.0
            R = 0.02 * d # inches
        elif condition == "combined":
            Kt = 2.7
            Kts = 2.2
            R = 0.02 * d # inches
        else:
            print(f"\nError: '{condition}' is not a valid shaft stress condition. Please enter 'bending', 'torsion', or 'axial'.\n")
    else:
        print(f"\nError: '{iter_estimate}' is not a valid stress concentration factor type. Please enter 'ring-groove', 'keyway', 'wide radius', or 'sharp radius'.\n")

    # Step 2: Compute Neuber constant based on material properties and loading condition
    if condition == "bending" or condition == "axial":
        if system == "imperial":
            if Sut >= 50 and Sut <= 250:   # KSI
                Neuber = 0.246 - 3.08e-3 * Sut + 1.51e-5 * Sut**2 - 2.67e-8 * Sut**3
            else:
                print(f"\nError: '{Sut}' is not a valid ultimate tensile strength for the bending or axial condition. Please enter a value between 50 and 250 KSI.\n")
        elif system == "metric":
            if Sut >= 340 and Sut <= 1700: # MPa
                Neuber = 1.24 - 2.25e-3 * Sut + 1.6e-6 * Sut**2 - 4.11e-10 * Sut**3
            else:
                print(f"\nError: '{Sut}' is not a valid ultimate tensile strength for the bending or axial condition. Please enter a value between 340 and 1700 MPa.\n")
    elif condition == "torsion":
        if system == "imperial":
            if Sut >= 50 and Sut <= 220:   # KSI
                Neuber = 0.190 - 2.51e-3 * Sut + 1.35e-5 * Sut**2 - 2.67e-8 * Sut**3
            else:
                print(f"\nError: '{Sut}' is not a valid ultimate tensile strength for the torsion condition. Please enter a value between 50 and 220 KSI.\n")
        elif system == "metric":
            if Sut >= 340 and Sut <= 1500: # MPa
                Neuber = 0.958 - 1.83e-3 * Sut + 1.43e-6 * Sut**2 - 4.11e-10 * Sut**3
            else:
                print(f"\nError: '{Sut}' is not a valid ultimate tensile strength for the torsion condition. Please enter a value between 340 and 1500 MPa.\n")
    elif condition == "combined":
        if system == "imperial":
            if (Sut >= 50 and Sut <= 220): # KSI
                Neuber_b = 0.246 - 3.08e-3 * Sut + 1.51e-5 * Sut**2 - 2.67e-8 * Sut**3
                Neuber_t = 0.190 - 2.51e-3 * Sut + 1.35e-5 * Sut**2 - 2.67e-8 * Sut**3
            else:
                print(f"\nError: '{Sut}' is not a valid ultimate tensile strength for the combined condition. Please enter a value between 50 and 220 KSI.\n")
        elif system == "metric":
            if Sut >= 340 and Sut <= 1500: # MPa
                Neuber_b = 1.24 - 2.25e-3 * Sut + 1.6e-6 * Sut**2 - 4.11e-10 * Sut**3
                Neuber_t = 0.958 - 1.83e-3 * Sut + 1.43e-6 * Sut**2 - 4.11e-10 * Sut**3
            else:
                print(f"\nError: '{Sut}' is not a valid ultimate tensile strength for the combined condition. Please enter a value between 340 and 1500 MPa.\n")
        else:
            print(f"\nError: '{system}' is not a valid system. Please enter 'imperial' or 'metric'.\n")

    # Step 3: Compute notch sensitivity (q or qs) and fatigue stress concentration factors (Kf, Kfs)
    if condition == "bending" or condition == "axial":
        q = 1/(1 + (Neuber/np.sqrt(R)))
    elif condition == "torsion":
        qs = 1/(1 + (Neuber/np.sqrt(R)))
    elif condition == "combined":
        q = 1/(1 + (Neuber_b/np.sqrt(R)))
        qs = 1/(1 + (Neuber_t/np.sqrt(R)))
    else:
        print(f"\nError: '{condition}' is not a valid shaft stress condition. Please enter 'bending', 'torsion', or 'axial'.\n")

    # Step 4: Compute fatigue stress concentration factors (Kf, Kfs)
    Kf = None
    Kfs = None
    if condition == "bending" or condition == "axial":
        Kf = 1.0 + q * (Kt - 1.0)
    elif condition == "torsion":
        Kfs = 1.0 + qs * (Kts - 1.0)
    elif condition == "combined":
        Kf = 1.0 + q * (Kt - 1.0)
        Kfs = 1.0 + qs * (Kts - 1.0)
    else:
        print(f"\nError: '{condition}' is not a valid shaft stress condition. Please enter 'bending', 'torsion', 'axial', or 'combined'.\n")

    return Kf, Kfs

